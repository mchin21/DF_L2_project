        <Param val="group1_trials_reps = 0&amp;#10;group2_trials_reps = 0&amp;#10;group3_trials_reps = 0&amp;#10;group4_trials_reps = 0" valType="extendedCode" updates="constant" name="Begin Experiment"/>
